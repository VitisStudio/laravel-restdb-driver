includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    level: max
    paths:
        - packages/contracts/src
        - packages/core/src
        - packages/jsonapi/src
        - packages/openapi/src
    ignoreErrors:
        # The model trait is consumed by applications, not by package code;
        # it is exercised by the test suite, which phpstan does not analyse.
        -
            identifier: trait.unused
            path: packages/core/src/Eloquent/InteractsWithRestApi.php
        -
            identifier: trait.unused
            path: packages/jsonapi/src/IsJsonApiResource.php
        -
            identifier: trait.unused
            path: packages/openapi/src/IsOpenApiResource.php
