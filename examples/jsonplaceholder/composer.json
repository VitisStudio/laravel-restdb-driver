{
    "name": "vitis/restdb-example-jsonplaceholder",
    "description": "Example Laravel app: Eloquent over the live JSONPlaceholder API via the restdb driver",
    "type": "project",
    "license": "MIT",
    "repositories": [
        {
            "type": "path",
            "url": "../../packages/*",
            "options": {
                "versions": {
                    "vitis/restdb-contracts": "0.1.0",
                    "vitis/restdb": "0.1.0",
                    "vitis/restdb-jsonapi": "0.1.0"
                }
            }
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0",
        "vitis/restdb-jsonapi": "^0.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
